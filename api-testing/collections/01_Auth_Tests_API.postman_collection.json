    {
      "name": "TC01 - Đăng ký: Số điện thoại đã tồn tại",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Kiểm tra xem web có phản hồi không (Status 200 OK)\r",
              "pm.test(\"Web phản hồi thành công (Status 200)\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Đọc toàn bộ mã HTML mà web trả về\r",
              "let htmlBody = pm.response.text();\r",
              "\r",
              "// 3. Quét xem trong mã HTML đó có hiển thị dòng chữ báo lỗi không\r",
              "pm.test(\"Báo lỗi chính xác: Số điện thoại đã tồn tại\", function () {\r",
              "    // CHÚ Ý: Nếu web của bạn báo lỗi bằng câu chữ khác, hãy sửa lại đoạn text bên dưới cho giống 100% với chữ trên web nhé.\r",
              "    pm.expect(htmlBody).to.include(\"Số điện thoại này đã được sử dụng\"); \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
