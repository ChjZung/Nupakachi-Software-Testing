        {
          "name": "TC16 - API lấy báo cáo doanh thu hợp lệ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "function isJsonResponse() {\r",
                  "    const contentType = pm.response.headers.get('Content-Type') || '';\r",
                  "    return contentType.toLowerCase().includes('application/json');\r",
                  "}\r",
                  "function bodyText() { return pm.response.text().toLowerCase(); }\r",
                  "function assertNotHtml(tc) {\r",
                  "    pm.test(tc + ' - Response không được là HTML', function () {\r",
                  "        pm.expect(bodyText()).to.not.include('<!doctype html>');\r",
                  "        pm.expect(bodyText()).to.not.include('<html');\r",
                  "    });\r",
                  "}\r",
                  "function assertJson(tc) {\r",
                  "    pm.test(tc + ' - Response phải là JSON', function () {\r",
                  "        pm.response.to.be.json;\r",
                  "    });\r",
                  "}\r",
                  "pm.test('TC16 - API revenue hợp lệ phải trả về 200', function () { pm.response.to.have.status(200); });\r",
                  "assertNotHtml('TC16');\r",
                  "assertJson('TC16');\r",
                  "if (pm.response.code === 200 && isJsonResponse()) {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.test('TC16 - Body có dữ liệu đúng nghiệp vụ', function () {\r",
                  "        const text = JSON.stringify(data).toLowerCase();\r",
                  "        pm.expect(text).to.satisfy(function (body) { return body.includes('revenue') || body.includes('doanhthu') || body.includes('tongdoanhthu') || body.includes('totalrevenue') || body.includes('orders') || body.includes('data'); });\r",
                  "    });\r",
                  "}\r"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
