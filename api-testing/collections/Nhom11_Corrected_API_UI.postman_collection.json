        {
          "name": "Login Page - Load trang đăng nhập",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login Page - Trang đăng nhập load thành công', function () { pm.response.to.have.status(200); });\r",
                  "pm.test('Login Page - Response là HTML', function () { pm.expect(pm.response.text().toLowerCase()).to.include('<!doctype html>'); });\r",
                  "pm.test('Login Page - Có form đăng nhập', function () { const body = pm.response.text().toLowerCase(); pm.expect(body).to.satisfy(function(t){ return t.includes('login') || t.includes('đăng nhập') || t.includes('dang nhap') || t.includes('matkhau') || t.includes('password'); }); });\r"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
