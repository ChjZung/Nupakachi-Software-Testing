      <!-- TC54 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC54 - Database timeout lọc dữ liệu lớn" enabled="true">
        <stringProp name="ThreadGroup.num_threads">80</stringProp>
        <stringProp name="ThreadGroup.ramp_time">40</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC54 - DB Timeout Test" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/BaocaoThongKe</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC55 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC55 - Error rate dưới tải thường" enabled="true">
        <stringProp name="ThreadGroup.num_threads">100</stringProp>
        <stringProp name="ThreadGroup.ramp_time">30</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC55 - Error Rate Test" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/ErrorTest</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC56 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC56 - Reliability 24h" enabled="true">
        <stringProp name="ThreadGroup.num_threads">50</stringProp>
        <stringProp name="ThreadGroup.ramp_time">30</stringProp>
        <stringProp name="ThreadGroup.duration">86400</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC56 - Continuous Load" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/BaocaoThongKe</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC57 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC57 - Memory Leak Check" enabled="true">
        <stringProp name="ThreadGroup.num_threads">50</stringProp>
        <stringProp name="ThreadGroup.ramp_time">20</stringProp>
        <stringProp name="ThreadGroup.duration">14400</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC57 - Memory Leak" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/BaocaoThongKe</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC58 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC58 - Long Session Testing" enabled="true">
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <stringProp name="ThreadGroup.duration">7200</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC58 - Long Session" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/QuanTriAdmin</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC59 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC59 - Repeated Export 100 lần" enabled="true">
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <stringProp name="LoopController.loops">100</stringProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC59 - Export Excel 100 times" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/ExportExcel</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC60 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC60 - Continuous API Requests" enabled="true">
        <stringProp name="ThreadGroup.num_threads">30</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <stringProp name="ThreadGroup.duration">21600</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC60 - Continuous API" enabled="true">
          <stringProp name="HTTPSampler.path">/api/reports/revenue</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC61 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC61 - Database Disconnection" enabled="true">
        <stringProp name="ThreadGroup.num_threads">40</stringProp>
        <stringProp name="ThreadGroup.ramp_time">20</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC61 - DB Failover" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/BaocaoThongKe</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- TC62 -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TC62 - Log File Full Test" enabled="true">
        <stringProp name="ThreadGroup.num_threads">30</stringProp>
        <stringProp name="ThreadGroup.ramp_time">15</stringProp>
        <stringProp name="ThreadGroup.duration">14400</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC62 - Log Test" enabled="true">
          <stringProp name="HTTPSampler.path">/Admin/BaocaoThongKe</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
